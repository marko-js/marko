<let/selected=1/>
<let/rows=[{ id: 1, label: "a" }, { id: 2, label: "b" }]/>
<ul>
  <for|row| of=rows by="id">
    <li class=(selected === row.id && "danger")>
      <button.toggle onClick() {
        selected = selected === row.id ? undefined : row.id;
      }>${row.label}</button>
    </li>
  </for>
</ul>
