static const initialValue = ["a"];
<let/value = initialValue/>

<select multiple value=initialValue>
  <option/>
  <option value="a"/>
</select>

<select multiple value=initialValue>
  <option/>
  <option value="b"/>
</select>

<select multiple value=value>
  <option/>
  <option value="b"/>
</select>

<select multiple value=value valueChange=undefined>
  <option/>
  <option value="b"/>
</select>

<button onClick() { value = ["a", "b"] }>
  Update
</button>
