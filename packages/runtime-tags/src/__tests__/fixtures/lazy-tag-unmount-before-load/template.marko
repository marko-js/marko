import Child from "./child.marko" with { load: "render" }
import { resolveAfter } from "../../utils/resolve"

<let/show=true>
<button onClick() { show = !show }>Toggle</button>
<if=show>
  <try>
    <await=resolveAfter(1, 1)>
      <Child value=1/>
    </await>
    <@placeholder>
      loading
    </@placeholder>
  </try>
</if>
